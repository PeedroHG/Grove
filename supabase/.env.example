# Copy to supabase/.env (gitignored) and fill in your own Meu Pluggy
# Development Application credentials from https://dashboard.pluggy.ai
#
# Apply to your project with:
#   supabase secrets set --env-file ./supabase/.env
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically into every Edge Function by the Supabase platform — do not
# set them here.

PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
